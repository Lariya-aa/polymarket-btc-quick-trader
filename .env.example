# Copy these values into ~/.poly_mm_env, not into this repository.
#
# Required for trading:
export POLY_PRIVATE_KEY=
export POLY_FUNDER_ADDRESS=
export POLY_SIGNATURE_TYPE=3

# Optional if you do not want the script to derive CLOB credentials:
export POLY_API_KEY=
export POLY_API_SECRET=
export POLY_API_PASSPHRASE=

# Optional notifications:
export SERVERCHAN_SENDKEY=

# Optional LLM prediction layer:
export MINIMAX_TOKEN_PLAN_KEY=
